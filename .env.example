# Backend
DATABASE_PATH=backend/data/incidentbuddy.db
RUNBOOKS_DIR=runbooks
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_TOKEN=dev-admin-change-me

# Light auth gate for mutating routes (run-agent, comms approve/reject,
# simulate-alert, loop pause/resume). Leave blank in dev to disable the gate.
# In prod, generate a random string and share via the judging URL: ?t=<token>
DEMO_TOKEN=

# LLM — TrueFoundry AI Gateway (OpenAI-compatible) or direct OpenAI
TRUEFOUNDRY_GATEWAY_URL=
TRUEFOUNDRY_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo
PRIMARY_LLM_MODEL=nvidia/nemotron
PRIMARY_LLM_PROVIDER=crusoe-nemotron
FALLBACK_LLM_PROVIDER=openai

# Continuous-demo loop (background scheduler keeps the dashboard alive 24/7)
DEMO_LOOP_ENABLED=true
LOOP_INTERVAL_SECONDS=60              # how often a new chaos incident spawns
LOOP_STATE_STEP_SECONDS=15            # state-machine advance cadence
LOOP_GC_MAX_INCIDENTS=50              # keep newest N visible, archive the rest
LOOP_LIVE_LLM_IDLE_MINUTES=15         # if no judge ping within window, use fixtures
LOOP_MAX_CONCURRENT_INCIDENTS=2

# SSE
SSE_KEEPALIVE_SECONDS=15
SSE_QUEUE_SIZE=256

# Frontend (Next.js proxy — required for /api routes in production)
BACKEND_URL=http://127.0.0.1:8000

# Optional
NAIVE_MODE=false

# --- Docker Compose overrides (set automatically in docker-compose.yml) ---
# DATABASE_PATH=/data/incidentbuddy.db
# BACKEND_URL=http://api:8080

# --- GCP Cloud Run (production) ---
# Store tokens/keys in Secret Manager — NOT in terraform.tfvars:
#   ./scripts/gcp-create-secrets.sh
# Copy terraform/terraform.tfvars.example → terraform/terraform.tfvars (project_id only)
# Deploy: export GCP_PROJECT_ID=... && make gcp-deploy
# See docs/DEPLOYMENT.md
